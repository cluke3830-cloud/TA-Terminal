# ─────────────────────────────────────────────────────────────────
# Quantum Terminal — Environment Variables
# Copy this file to .env (or .env.local) and fill in your keys.
# .env / .env.local are gitignored and never leave your machine.
# ─────────────────────────────────────────────────────────────────

# ── Equity / Options data ──────────────────────────────────────
# Alpaca: https://alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here

# FMP: https://financialmodelingprep.com → Dashboard → API Keys
# Used for financials, FX, commodities, economic calendar.
FMP_API_KEY=your_fmp_key_here

# ── Macro Analysis page ────────────────────────────────────────
# FRED: https://fred.stlouisfed.org/docs/api/api_key.html (free, instant)
# Provides US Treasury yield curve and Fed Funds rate.
FRED_API_KEY=your_fred_key_here

# EIA:  https://www.eia.gov/opendata/register.php (free, instant)
# Provides US electricity wholesale prices.
EIA_API_KEY=your_eia_key_here

# OpenSky Network and World Bank APIs are public — no key required.