# ─────────────────────────────────────────────
#  Quantum Terminal — Environment Variables
#  Copy this file to .env.local and fill in your keys.
#  Never commit .env.local — it is in .gitignore.
# ─────────────────────────────────────────────

# ── AMD MI300X GPU Droplet ───────────────────
# Your AMD Developer Cloud droplet running telemetry.py + Ollama
# Sign up: https://www.amd.com/en/developer/resources/cloud-access.html
# Default points to the hackathon droplet — replace with your own IP
AMD_TELEMETRY_URL=http://<YOUR_DROPLET_IP>:8000
MC_GPU_URL=http://<YOUR_DROPLET_IP>:8000
REGIME_API_URL=http://<YOUR_DROPLET_IP>:8000

# ── Financial Modeling Prep ──────────────────
# Used for 13F institutional ownership data (optional — Yahoo Finance fallback is active)
# Free tier: 250 requests/day   Paid: https://site.financialmodelingprep.com/developer/docs/pricing
# Get key: https://financialmodelingprep.com/developer/docs
FMP_API_KEY=

# ── FRED (Federal Reserve Economic Data) ────
# Used for macro indicators (interest rates, CPI, unemployment)
# Free API — no credit card required
# Get key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ── EIA (U.S. Energy Information Administration) ─
# Used for crude oil / natural gas data on the macro page
# Free API — no credit card required
# Get key: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# ── Alpaca Markets ───────────────────────────
# Used for real-time quotes and options data
# Free paper trading account works for market data
# Get key: https://app.alpaca.markets/signup
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ── Anthropic (Claude) ───────────────────────
# Used for AI-powered analysis features (optional)
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── OpenSky Network ──────────────────────────
# Used for live flight/cargo data (macro page)
# Free account — register at: https://opensky-network.org/index.php?option=com_users&view=registration
OPENSKY_USERNAME=
OPENSKY_PASSWORD=